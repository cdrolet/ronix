{
  description = "Nix Configuration - Multi-platform";

  inputs = {
    nixpkgs.url = "github:NixOS/nixpkgs/nixpkgs-unstable";

    nix-darwin = {
      url = "github:LnL7/nix-darwin";
      inputs.nixpkgs.follows = "nixpkgs";
    };

    home-manager = {
      url = "github:nix-community/home-manager";
      inputs.nixpkgs.follows = "nixpkgs";
    };

    sops-nix = {
      url = "github:Mic92/sops-nix";
      inputs.nixpkgs.follows = "nixpkgs";
    };

    nix-on-droid = {
      url = "github:nix-community/nix-on-droid/release-23.11";
      inputs.nixpkgs.follows = "nixpkgs";
      inputs.home-manager.follows = "home-manager";
    };
  };

  outputs = {
    self,
    nixpkgs,
    nix-darwin,
    home-manager,
    sops-nix,
    nix-on-droid,
    ...
  } @ inputs: let
    # Valid users and profiles for the new structure
    validUsers = ["cdrokar" "cdrolet" "cdrixus"];
    validProfiles = {
      darwin = ["home-macmini-m4" "work"];
      linux = ["gnome-desktop-1" "kde-desktop-1" "server-1"];
    };

    # Helper function to create system configurations
    mkSystem = system: modules:
      nixpkgs.lib.nixosSystem {
        inherit system modules;
        specialArgs = {inherit inputs;};
      };

    # Helper function to create darwin configurations
    mkDarwin = system: modules:
      nix-darwin.lib.darwinSystem {
        inherit system modules;
        specialArgs = {inherit inputs;};
      };

    # Helper function to create home-manager configurations
    mkHome = system: username: modules:
      home-manager.lib.homeManagerConfiguration {
        pkgs = import nixpkgs {
          inherit system;
          config.allowUnfree = true;
        };
        modules = modules;
        extraSpecialArgs = {inherit inputs;};
      };

    # NEW: Helper to create darwin config with user/system split
    mkDarwinConfig = {
      user,
      profile,
      system ? "aarch64-darwin",
    }:
      nix-darwin.lib.darwinSystem {
        inherit system;
        specialArgs = {inherit inputs;};
        modules = [
          # System profile (includes system settings + apps)
          ./system/darwin/profiles/${profile}

          # Set primary user for nix-darwin multi-user support
          {
            # Primary user for system.defaults that affect user preferences
            system.primaryUser = user;
          }

          # Home Manager integration
          home-manager.darwinModules.home-manager
          {
            home-manager.useGlobalPkgs = true;
            home-manager.useUserPackages = true;
            home-manager.users.${user} = {
              imports = [
                # User configuration (includes user-specific apps)
                ./user/${user}
              ];
            };
          }
        ];
      };
  in {
    # Export validation lists for justfile
    inherit validUsers validProfiles;
    # macOS (nix-darwin) configurations
    darwinConfigurations = {
      # NEW STRUCTURE: User/system split configurations
      cdrokar-home-macmini-m4 = mkDarwinConfig {
        user = "cdrokar";
        profile = "home-macmini-m4";
      };

      cdrokar-work = mkDarwinConfig {
        user = "cdrokar";
        profile = "work";
      };

      cdrolet-work = mkDarwinConfig {
        user = "cdrolet";
        profile = "work";
      };

      cdrixus-home-macmini-m4 = mkDarwinConfig {
        user = "cdrixus";
        profile = "home-macmini-m4";
      };


    };

    # NixOS configurations
    # TODO: Add NixOS configurations with new structure in future phases
    nixosConfigurations = {};

    # Standalone Home Manager configurations
    # TODO: Add standalone Home Manager configs with new structure
    homeConfigurations = {};

    # Nix-on-Droid configurations
    # TODO: Add Nix-on-Droid configs with new structure
    nixOnDroidConfigurations = {};

    # Formatter for `nix fmt`
    formatter = {
      aarch64-darwin = nixpkgs.legacyPackages.aarch64-darwin.alejandra;
      x86_64-darwin = nixpkgs.legacyPackages.x86_64-darwin.alejandra;
      x86_64-linux = nixpkgs.legacyPackages.x86_64-linux.alejandra;
      aarch64-linux = nixpkgs.legacyPackages.aarch64-linux.alejandra;
    };
  };
}
